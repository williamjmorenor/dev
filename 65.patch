+{% macro detail_header(title, status_value, buttons_html='') %}
+{% set status_badge = 'bg-secondary' %}
+{% if status_value == 'submitted' or status_value == 1 %}
+    {% set status_badge = 'bg-success' %}
+{% elif status_value == 'rejected' or status_value == 'cancelled' or status_value == 2 %}
+    {% set status_badge = 'bg-danger' %}
+{% endif %}
+
+<div class="ca-journal-toolbar mb-3">
+  <div>
+    <h4 class="mb-1">{{ title }}</h4>
+    <p class="text-muted mb-0">
+        <span class="badge {{ status_badge }}">{{ status_value }}</span>
+    </p>
+  </div>
+  <div class="d-flex gap-2 flex-wrap">
+    {{ buttons_html | safe }}
+  </div>
+</div>
+{% endmacro %}
+
+{% macro detail_kv_list(items) %}
+<div class="ca-card">
+    <div class="row g-3 p-3">
+        {% for label, value in items %}
+        <div class="col-md-6">
+            <div class="ca-kv-item">
+                <label>{{ label }}</label>
+                <p>{{ value or '-' }}</p>
+            </div>
+        </div>
+        {% endfor %}
+    </div>
+</div>
+{% endmacro %}
