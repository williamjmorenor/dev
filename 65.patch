diff --git a/cacao_accounting/templates/transaction_form_macros.html b/cacao_accounting/templates/transaction_form_macros.html
new file mode 100644
index 00000000..236597fe
--- /dev/null
+++ b/cacao_accounting/templates/transaction_form_macros.html
@@ -0,0 +1,193 @@
+{% macro transaction_form_js(config) %}
+<script>
+  window.transactionFormConfig = {{ config | tojson | safe }};
+</script>
+{% endmacro %}
+
+{% macro transaction_form_header(title, status_label='Borrador') %}
+<div class="ca-journal-toolbar mb-3">
+  <div>
+    <h4 class="mb-1">{{ title }}</h4>
+    <p class="text-muted mb-0">{{ status_label }}</p>
+  </div>
+  <div class="d-flex gap-2">
+    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#columnsModal">
+      <i class="bi bi-sliders"></i> {{ _('Columnas') }}
+    </button>
+    <a href="#" class="btn btn-sm btn-outline-danger" onclick="history.back(); return false;">{{ _('Cancelar') }}</a>
+    <button class="btn btn-sm btn-primary" type="submit" form="form-main">
+      <i class="bi bi-save"></i> {{ _('Guardar') }}
+    </button>
+  </div>
+</div>
+{% endmacro %}
+
+{% macro transaction_grid(items_disponibles, uoms_disponibles, source_api_url=None, source_label='') %}
+<section class="border rounded-2 p-3 mt-3">
+    <div class="ca-journal-toolbar mb-3">
+      <h5 class="mb-0">{{ _('Líneas de detalle') }}</h5>
+      <div class="d-flex gap-2">
+        {% if source_api_url %}
+        <button class="btn btn-sm btn-outline-secondary" type="button"
+                data-bs-toggle="modal" data-bs-target="#modalAutofill"
+                @click="fetchSource('{{ source_api_url }}')">
+          <i class="bi bi-arrow-repeat"></i> {{ _('Actualizar Elementos') }}
+        </button>
+        {% endif %}
+        <button class="btn btn-sm btn-outline-primary" type="button" @click="addRow()">{{ _('Añadir fila') }}</button>
+      </div>
+    </div>
+    <div class="ca-journal-grid">
+      <table class="table table-sm table-bordered ca-journal-table">
+        <thead>
+          <tr>
+            <th style="width: 52px;">{{ _('No.') }}</th>
+            <template x-for="column in visibleColumns" :key="column.field">
+              <th :style="'width:' + (column.width * 90) + 'px'" x-text="column.label"></th>
+            </template>
+            <th style="width: 120px;">{{ _('Acciones') }}</th>
+          </tr>
+        </thead>
+        <tbody>
+          <template x-for="(line, index) in lines" :key="line.uid">
+            <tr>
+              <td class="text-center" x-text="index + 1"></td>
+              <template x-for="column in visibleColumns" :key="column.field">
+                <td>
+                  <template x-if="column.field === 'item_code'">
+                    <select :name="'item_code_' + index" x-model="line.item_code" class="form-select form-select-sm">
+                        <option value=""></option>
+                        {% for item in items_disponibles %}
+                        <option value="{{ item.code }}">{{ item.code }} — {{ item.name }}</option>
+                        {% endfor %}
+                    </select>
+                  </template>
+                  <template x-if="column.field === 'qty'">
+                    <input class="form-control form-control-sm text-end" type="number" step="0.0001" min="0"
+                      :name="'qty_' + index" x-model.number="line.qty" @input="calcAmount(line)">
+                  </template>
+                  <template x-if="column.field === 'uom'">
+                     <select :name="'uom_' + index" x-model="line.uom" class="form-select form-select-sm">
+                        <option value=""></option>
+                        {% for uom in uoms_disponibles %}
+                        <option value="{{ uom.code }}">{{ uom.code }}</option>
+                        {% endfor %}
+                    </select>
+                  </template>
+                  <template x-if="column.field === 'rate'">
+                    <input class="form-control form-control-sm text-end" type="number" step="0.0001" min="0"
+                      :name="'rate_' + index" x-model.number="line.rate" @input="calcAmount(line)">
+                  </template>
+                  <template x-if="column.field === 'amount'">
+                    <div class="text-end px-2">
+                        <span x-text="formatMoney(line.amount)"></span>
+                        <input type="hidden" :name="'amount_' + index" :value="line.amount">
+                    </div>
+                  </template>
+                  <template x-if="column.field === 'item_name'">
+                    <input class="form-control form-control-sm" type="text" :name="'item_name_' + index" x-model="line.item_name">
+                  </template>
+                </td>
+              </template>
+              <td>
+                <div class="ca-journal-actions">
+                  <button class="btn btn-sm btn-outline-secondary" type="button" @click="duplicateRow(index)"
+                    title="{{ _('Duplicar') }}"><i class="bi bi-copy"></i></button>
+                  <button class="btn btn-sm btn-outline-danger" type="button" @click="removeRow(index)"
+                    title="{{ _('Eliminar') }}"><i class="bi bi-trash"></i></button>
+                </div>
+              </td>
+              <input type="hidden" :name="'source_type_' + index" x-model="line.source_type">
+              <input type="hidden" :name="'source_id_' + index" x-model="line.source_id">
+              <input type="hidden" :name="'source_item_id_' + index" x-model="line.source_item_id">
+            </tr>
+          </template>
+        </tbody>
+      </table>
+    </div>
+</section>
+
+{% if source_api_url %}
+<div class="modal fade" id="modalAutofill" tabindex="-1" aria-hidden="true">
+    <div class="modal-dialog modal-lg modal-dialog-scrollable">
+      <div class="modal-content">
+        <div class="modal-header">
+          <h5 class="modal-title">
+            <i class="bi bi-table me-2"></i>{{ _('Actualizar Elementos desde') }} {{ source_label }}
+          </h5>
+          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
+        </div>
+        <div class="modal-body">
+          <div x-show="loadingSource" class="text-center py-3">
+            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
+            {{ _('Cargando elementos...') }}
+          </div>
+          <div x-show="!loadingSource">
+            <table class="table table-sm ca-table">
+              <thead>
+                <tr>
+                  <th style="width:5%"><input type="checkbox" @change="sourceItems.forEach(i => i.selected = $event.target.checked)"></th>
+                  <th>{{ _('Código') }}</th>
+                  <th>{{ _('Descripción') }}</th>
+                  <th>{{ _('Pendiente') }}</th>
+                  <th>{{ _('Traer') }}</th>
+                </tr>
+              </thead>
+              <tbody>
+                <template x-for="(si, idx) in sourceItems" :key="idx">
+                  <tr>
+                    <td><input type="checkbox" x-model="si.selected"></td>
+                    <td x-text="si.item_code"></td>
+                    <td x-text="si.item_name"></td>
+                    <td x-text="Number(si.pending_qty || si.qty || 0).toFixed(4)"></td>
+                    <td>
+                      <input type="number" x-model.number="si.qty" min="0.0001"
+                             :max="si.pending_qty || si.qty" step="0.0001"
+                             class="form-control form-control-sm" style="width:90px">
+                    </td>
