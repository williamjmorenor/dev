+              <button class="btn btn-sm btn-outline-secondary" type="button" @click="moveColumn(index, -1)"><i
+                  class="bi bi-arrow-up"></i></button>
+              <button class="btn btn-sm btn-outline-secondary" type="button" @click="moveColumn(index, 1)"><i
+                  class="bi bi-arrow-down"></i></button>
+            </div>
+          </template>
+        </div>
+        <div class="modal-footer">
+          <button class="btn btn-outline-secondary" type="button" @click="resetPreferences()">{{ _('Restablecer') }}</button>
+          <button class="btn btn-primary" type="button" @click="savePreferences()">{{ _('Actualizar') }}</button>
+        </div>
+      </div>
+    </div>
+</div>
+{% endmacro %}
